# ─── AlphaWeek Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get both from https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alphaweek?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx-direct.us-east-1.aws.neon.tech/alphaweek?sslmode=require

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from Clerk Dashboard → Webhooks → Add endpoint → Signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── AI (Groq — free tier, Llama 3.3 70B) ────────────────────────────────────
# Get from https://console.groq.com → API Keys (free, no credit card)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cache (Redis / Upstash) ──────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: redis://default:password@your-region.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sending domain — configure at resend.com/domains
RESEND_FROM_EMAIL=briefs@alphaweek.io
RESEND_FROM_NAME=AlphaWeek

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
# Get from https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=alphaweek-briefs
# Public URL for your R2 bucket (enable public access in R2 settings)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─── Frontend URL ─────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Optional: News API ───────────────────────────────────────────────────────
# Get from https://newsapi.org → Get API Key (free tier: 100 req/day)
# If not set, geo-political events section uses no news data.
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ─── Optional: Telegram Bot ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
# If not set, Telegram delivery is disabled.
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The @username of your bot (without the @) — used to build the connect deeplink.
# Find it in @BotFather → /mybots → your bot → Edit Bot → Edit Username
TELEGRAM_BOT_USERNAME=AlphaWeekBot
# A secret token you choose (any random string, 1-256 chars, alphanumeric + _ and -)
# Pass it when registering your webhook:
# https://api.telegram.org/bot{TOKEN}/setWebhook?url=...&secret_token={THIS_VALUE}
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# ─── Optional: Reddit (Elite/WhiteLabel sentiment analysis) ───────────────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
# If not set, Reddit sentiment section is skipped for Elite briefs.
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=AlphaWeek/1.0 by u/your_username

# ─── Optional: Sentry (Error tracking) ───────────────────────────────────────
# Get from https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://xxxx@oxx.ingest.sentry.io/xxxx

# ─── Optional: Admin API ──────────────────────────────────────────────────────
# Arbitrary secret for /admin/* endpoints (generate with: openssl rand -hex 32)
ADMIN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional: Worker ─────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ─── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:hello@alphaweek.io
