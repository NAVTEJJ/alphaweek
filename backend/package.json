{
  "name": "alphaweek-api",
  "version": "1.0.0",
  "description": "AlphaWeek — AI-Powered Weekly Investment Intelligence API",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npx prisma generate",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:neon": "node scripts/migrate.mjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "@clerk/backend": "^1.13.0",
    "@clerk/express": "^1.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.16.0",
    "@sentry/node": "^8.19.0",
    "@types/web-push": "^3.6.4",
    "bullmq": "^5.12.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "groq-sdk": "^0.9.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "puppeteer": "^22.12.0",
    "resend": "^3.4.0",
    "svix": "^1.24.0",
    "web-push": "^3.6.7",
    "winston": "^3.13.0",
    "yahoo-finance2": "^2.11.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "pg": "^8.20.0",
    "prisma": "^5.16.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.ts"
    ],
    "moduleNameMapper": {
      "^../../config/redis$": "<rootDir>/config/__mocks__/redis.ts",
      "^../../../config/redis$": "<rootDir>/config/__mocks__/redis.ts"
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ]
  }
}
