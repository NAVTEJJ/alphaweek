# ─── AlphaWeek Frontend — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── API ──────────────────────────────────────────────────────────────────────
# Local backend: http://localhost:4000
# Production:    https://api.alphaweek.io (or your Railway URL)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs — keep these as-is for local dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Analytics (PostHog) ──────────────────────────────────────────────────────
# Get from https://app.posthog.com → Project → Settings → Project API Key
# Optional — if not set, analytics tracking is silently disabled.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Must match VAPID_PUBLIC_KEY in backend/.env — copy it here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
