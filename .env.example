# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alphaweek?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alphaweek?sslmode=require&pgbouncer=true

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=alphaweek-briefs
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...
STRIPE_WHITELABEL_PRICE_ID=price_...

# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── News & Market Data ─────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key

# ─── Delivery ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=briefs@alphaweek.io
RESEND_FROM_NAME=AlphaWeek

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://:alphaweek_redis_dev@localhost:6379

# ─── Reddit ─────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AlphaWeek/1.0 by YourRedditUsername

# ─── Monitoring ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
JWT_SECRET=generate_a_64_char_random_string_here

# ─── Frontend (Next.js public vars) ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
